# Database
JDBC_DATABASE_URL=jdbc:postgresql://localhost:5432/zeeshop
JDBC_DATABASE_USERNAME=zeeshop_user
JDBC_DATABASE_PASSWORD=zeeshop_password
JDBC_DATABASE_DRIVER=org.postgresql.Driver

# Server
SERVER_PORT=8083

# JPA
JPA_DDL_AUTO=update
JPA_SHOW_SQL=true

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Logging
LOG_LEVEL=INFO
SQL_LOG_LEVEL=DEBUG
LOG_FILE=logs/zeeshop-server.log
