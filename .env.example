# App environment — leave as "local" for local dev. Any other value (e.g. staging,
# production) makes the app refuse to start unless JWT_SECRET / ADMIN_PASSWORD below
# are also changed from their defaults (see StartupSecretsValidator).
APP_ENV=local

# Database
JDBC_DATABASE_URL=jdbc:postgresql://localhost:5432/zeeshop
JDBC_DATABASE_USERNAME=zeeshop_user
JDBC_DATABASE_PASSWORD=zeeshop_password
JDBC_DATABASE_DRIVER=org.postgresql.Driver

# Server
SERVER_PORT=8083

# JPA
JPA_DDL_AUTO=update
JPA_SHOW_SQL=true

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# JWT — generate a strong random value for JWT_SECRET in every non-local environment
JWT_SECRET=dev-only-secret-do-not-use-in-production-1234567890abcdef
JWT_ACCESS_TOKEN_EXPIRATION_MS=900000
JWT_REFRESH_TOKEN_EXPIRATION_MS=604800000

# Seeded admin user (created on first startup if no users exist)
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@zeeshop.com
ADMIN_PASSWORD=ChangeMe123!

# Logging
LOG_LEVEL=INFO
SQL_LOG_LEVEL=DEBUG
LOG_FILE=logs/zeeshop-server.log
